{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./frontend",
    "paths": {
      "react": ["node_modules/react"],
      "react-dom": ["node_modules/react-dom"],
      "*": ["node_modules/*", "src/*"]
    }
  },
  "include": ["frontend/src/**/*"]
}
